# customized prompt
export PS1='$ '

# default editor
export EDITOR=emacsclient

# quick docker run (example: dr haskell ghci)
function dr() {
  if type docker > /dev/null; then
    docker run -v $PWD:/app -it --rm $1 ${2:bash}
  fi
}

function docker_gc() {
  echo "remove containers ..."
  docker ps -aq -f status=exited | xargs -r docker rm

  echo "remove volumes ..."
  docker volume ls -q -f dangling=true | grep ".\{64\}" | xargs -r docker volume rm

  echo "remove images ..."
  docker images -aq -f dangling=true | xargs -r docker rmi
}

# rbenv: https://github.com/rbenv/rbenv
if [ -d ~/.rbenv/bin ]; then
  export PATH="$HOME/.rbenv/bin:$PATH"
  eval "$(rbenv init -)"
fi

# nvm: https://github.com/creationix/nvm
if [ -d ~/.nvm ]; then
  export NVM_DIR="~/.nvm"
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
fi

# cscope index setup
function cscope_init() {
  if type cscope > /dev/null; then
    rm -f cscope.files
    for ext in c cc cpp h s S; do
      find . -name "*.$ext" -print >> cscope.files
    done
    cscope -b -q -k
  fi
}

# Rescue from system glitches
function rescue_network() {
  if lsmod | awk '$1 ~ /e1000e/' | read; then
    sudo modprobe -r e1000e
    sudo modprobe e1000e
  else
    echo 'kernel module e1000e not found'
  fi

  if lsmod | awk '$1 ~ /iwlwifi/' | read; then
    sudo modprobe -r iwlwifi
    sudo modprobe iwlwifi
  else
    echo 'kernel module e1000e not found'
  fi
}

function rescue_display() {
  xrandr -s 1366x768
}

function set_depot_tools_path() {
  export PATH=$HOME/repositories/others/depot_tools:$PATH
}

function set_android_studio_path() {
  export PATH=$HOME/repositories/downloads/path/android-studio/bin:$PATH
}

function caps_as_ctrl() {
  sudo loadkeys ~/repositories/my/keymap/caps_as_ctrl.map
}

function set_path_gradle() {
  export GRADLE_HOME=$HOME/repositories/downloads/gradle-3.2.1
  export PATH=$GRADLE_HOME/bin:$PATH
}

function set_java() {
  export JAVA_HOME=/usr/lib/jvm/default-java
}
